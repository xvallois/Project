{
  "compilerOptions": {
    "target": "ES2022", "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext", "moduleResolution": "bundler",
    "jsx": "react-jsx", "strict": true, "skipLibCheck": true,
    "noUnusedLocals": false, "noEmit": true, "types": ["vitest/globals"]
  },
  "include": ["src"]
}
